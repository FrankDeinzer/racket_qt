{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-x64",
      "displayName": "Windows x64 (MSVC 2022)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows-x64",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/6.11.0/msvc2022_64"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 (Ninja/Clang)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/usr/local/Qt/6.11.0/macos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_BUILD_RPATH": "/usr/local/Qt/6.11.0/macos/lib"
      }
    },
    {
      "name": "macos-x64",
      "displayName": "macOS x86_64 (Ninja/Clang)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/usr/local/Qt/6.11.0/macos",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_BUILD_RPATH": "/usr/local/Qt/6.11.0/macos/lib"
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux x86_64 (Ninja/GCC)",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/opt/Qt/6.11.0/gcc_64",
        "CMAKE_BUILD_RPATH": "/opt/Qt/6.11.0/gcc_64/lib"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "macos-arm64",
      "configurePreset": "macos-arm64"
    },
    {
      "name": "macos-x64",
      "configurePreset": "macos-x64"
    },
    {
      "name": "linux-x64",
      "configurePreset": "linux-x64"
    }
  ]
}
